package boogy:platform@0.1.0;

interface runtime {
    now-millis: func() -> u64;
    random-bytes: func(len: u32) -> list<u8>;
    log: func(level: string, message: string);

    /// The host-pinned identity of the CURRENTLY-EXECUTING service:
    /// the `(owner, service-id)` of the deployment whose route matched
    /// (at the HTTP edge), the CALLEE's identity on a `peer::fetch` hop
    /// (never the caller's), or the job's `(owner, service)` in a
    /// background job. Always set host-side from routing / the callee
    /// workload / the job target — never derived from any guest-supplied
    /// value or inbound header, so a service cannot spoof its own
    /// identity. Ungated: knowing your own identity is benign and always
    /// available (conceptually like reading the clock).
    record service-identity {
        owner: string,
        service-id: string,
    }
    self-identity: func() -> service-identity;

    /// True iff the CALLER's owner account equals THIS service's owner — i.e.
    /// the call is from the provisioner themselves (their agent token, resolved
    /// host-side via the agents registry) or one of their own workloads
    /// (`boogy://<owner>/...`). False for anonymous callers, a different owner,
    /// or when the caller's account can't be resolved (FAIL-CLOSED). Host-
    /// attested from the inbound identity — never guest-supplied — so it is safe
    /// to authorize on (e.g. an owner-only `/admin` surface in a provisionable
    /// module, which can't hardcode an owner identity in its manifest). Ungated,
    /// like `self-identity`.
    caller-is-service-owner: func() -> bool;
}
