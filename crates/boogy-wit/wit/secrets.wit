package boogy:platform@0.1.0;

/// Host-mediated operations over manifest-declared `[secrets]` that never
/// return the plaintext to the wasm component.
///
/// Distinct from `outbound-http`'s `secret-headers` (which injects a
/// secret at the wire edge): this interface lets a service ask the host
/// to *use* a secret in a computation — verifying an inbound webhook
/// signature — and only ever receive the boolean / typed-error outcome.
/// The secret value, the message, and the computed tag stay host-side.
interface secrets {
    enum hmac-algorithm { sha256 }

    variant verify-error {
        /// Secret ref not declared in `[secrets]`, or declared without the
        /// `hmac-verify` usage, or no value bound for this deployment.
        unknown-secret(string),
        /// Capability not granted / internal host error.
        internal(string),
    }

    /// Verify `expected-hex` == HMAC(secret[secret-ref], message) host-side.
    /// The component never receives the secret value.
    verify-hmac: func(
        secret-ref: string,
        algorithm: hmac-algorithm,
        message: list<u8>,
        expected-hex: string,
    ) -> result<bool, verify-error>;
}
